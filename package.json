{
  "name": "open-xiaoai-agent",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "db:ps": "docker compose ps",
    "dev": "concurrently -k -n go,web -c cyan,magenta \"npm:dev:go\" \"npm:dev:web\"",
    "dev:go": "go run .",
    "dev:web": "npm run dev --workspace web -- --host 0.0.0.0",
    "build:web": "npm run build --workspace web",
    "preview:web": "npm run preview --workspace web -- --host 0.0.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
